# ── Auth (required for the dashboard) ──
DASHBOARD_PASSWORD=change-me-to-something-long
DASHBOARD_SECRET=replace-with-32-bytes-of-random-hex

# ── Public site URL (used in canonical, sitemap, OG, JSON-LD) ──
NEXT_PUBLIC_SITE_URL=https://omartabboush.com

# ── Database ──
# Leave unset locally — falls back to file:./local.db (SQLite).
# In production (Vercel), point at a Turso / LibSQL database.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-jwt-here
